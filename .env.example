# Discord bot token (from https://discord.com/developers/applications)
DISCORD_TOKEN=

# The server (guild) and channel the bot should watch for Steam links.
# Enable Developer Mode in Discord, right-click -> "Copy ID".
WATCH_GUILD_ID=
WATCH_CHANNEL_ID=

# Command prefix and where to keep the SQLite file (optional).
COMMAND_PREFIX=!
DB_PATH=games.db

# --- Voting web app (web.py) ------------------------------------------------
# From your Discord application's OAuth2 settings. The redirect URI must be added
# to the app's "Redirects" list and match exactly. Use a separate Discord app (or
# at least a separate redirect URI) per environment so staging and production
# don't share a login.
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:8000/callback

# Signs the session cookie; keep it secret and stable. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
WEB_SECRET_KEY=

# Host port the web app is published on (Docker). Optional; defaults to 8000.
WEB_PORT=8000

# Set to 1 in any HTTPS deployment so the login session cookie is only ever sent
# over TLS. Leave blank for local http testing. Strongly recommended in prod.
COOKIE_SECURE=
